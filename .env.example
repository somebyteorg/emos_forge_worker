# EMOS 后台地址，必填。
EMOS_URL=https://emos.best

# EMOS 授权 token，必填。
EMOS_TOKEN=

# worker 命令必填；upload 命令不需要。只作为 worker 相关接口 URL 参数使用。
EMOS_FORGE_WORKER_ID=

# 输出目录，默认 ./output。
FORGE_OUTPUT_DIR=./output

# CPU 使用上限，默认 4。
# 会影响 ffmpeg 等处理步骤的并发和线程数。
FORGE_CPU_LIMIT=4

# 视频/音频封装加密模式，默认 clearkey。
# 如需关闭加密可改为 none。
# FORGE_ENCRYPTION_MODE=clearkey

# 雪碧图中间帧格式，默认 png。
# 可选值：png、ppm。
FORGE_SPRITE_FRAME_FORMAT=png

# EMOS 超时时间，默认 15s。
FORGE_HTTP_TIMEOUT=15s

# 上传并发数，默认 10。
EMOS_UPLOAD_CONCURRENCY=10

# 单文件上传最大重试次数，默认 3。
EMOS_UPLOAD_RETRY_MAX=3

# 上传完成后是否自动删除产物。
EMOS_UPLOAD_DELETE_ARTIFACTS=false

# 是否只上传带 title 的字幕，默认 true。
# 关闭后会上传 manifest 中的全部文本字幕。
EMOS_UPLOAD_TITLED_SUBTITLES_ONLY=true

# 如果外部工具不在 PATH 中，再取消注释并改成绝对路径。
# FORGE_FFMPEG_PATH=ffmpeg
# FORGE_FFPROBE_PATH=ffprobe
# FORGE_PACKAGER_PATH=packager
# FORGE_VIPS_PATH=vips
